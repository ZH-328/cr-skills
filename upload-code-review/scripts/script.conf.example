[DEFAULT]
# Aegis API Configuration
# API服务器地址
AEGIS_BASE_URL=http://localhost:8000/api
# 前端地址，用于生成审查结果链接；留空时从 AEGIS_BASE_URL 去掉 /api 后派生
AEGIS_WEB_URL=http://localhost:3000

# 登录凭据
AEGIS_USERNAME=superadmin
AEGIS_PASSWORD=123456

# 项目默认信息
# REPO_ID 留空时，会通过最终 gitlab_url 调用 GitLab API 自动获取
# REPO_NAME 留空时，会通过最终 gitlab_url 自动提取 group/project
REPO_ID= 
REPO_NAME= 
